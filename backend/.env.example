APP_ENV=dev
DATABASE_URL=sqlite:///./app.db
ROUTER_API_KEYS=demo-router-key
ALLOWED_ORIGINS=http://localhost:5159,http://localhost:5173
JWT_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me
# Fernet key used to encrypt BYOK provider secrets at rest.
# Generate once per environment:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ROUTER_SECRET_KEY=change-me-to-a-fernet-key
# Fallback provider HTTP timeouts in seconds. Chat routing uses
# RouteRule.timeout_ms when a model-specific route exists.
PROVIDER_TIMEOUT_INTERNAL_S=15
PROVIDER_TIMEOUT_EXTERNAL_S=300
PROVIDER_PROVIDER_PRIMARY_BASE_URL=
PROVIDER_PROVIDER_PRIMARY_API_KEY=
